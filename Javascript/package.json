{
    "name": "learning-javascript",
    "version": "1.0.0",
    "description": "",
    "license": "ISC",
    "author": "",
    "type": "commonjs",
    "main": "index.js",
    "scripts": {
        "watch:sass": "sass sass/main.scss css/style.css -w",
        "compile:sass": "sass sass/main.scss css/style.comp.css",
        "prefix:css": "postcss --use autoprefixer -b 'last 10 versions' css/style.comp.css -o css/style.prefix.cs",
        "compress:css": "sass css/style.prefix.cs css/style.css --style compressed",
        "build:css": "npm-run-all compile:sass prefix:css compress:css"
    },
    "devDependencies": {
        "autoprefixer": "^10.5.0",
        "dotenv": "^17.4.2",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.14",
        "postcss-cli": "^11.0.1",
        "sass": "^1.99.0"
    }
}
